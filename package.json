    "@types/node": "^24.12.3",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/tsconfig": "^0.9.1",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^5.4.21",
    "vue-tsc": "^3.2.8"
